{
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh -c 'f=\"$CLAUDE_PROJECT_DIR/.claude/hooks/gate-on-stop.sh\"; [ -x \"$f\" ] && exec \"$f\"; exit 0'",
            "timeout": 180
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|MultiEdit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "sh -c 'f=\"$CLAUDE_PROJECT_DIR/.claude/hooks/changeset-reminder.sh\"; [ -x \"$f\" ] && exec \"$f\"; exit 0'",
            "timeout": 15
          }
        ]
      }
    ]
  }
}

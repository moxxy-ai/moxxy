{
  "name": "moxxy",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Block-based, modular agentic loop framework.",
  "packageManager": "pnpm@10.30.0",
  "engines": {
    "node": ">=20.10.0"
  },
  "scripts": {
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "eslint .",
    "test": "turbo run test && pnpm run test:scripts",
    "test:scripts": "node --test scripts/*.test.mjs",
    "test:watch": "turbo run test:watch --concurrency=1",
    "check:deps": "depcruise --config .dependency-cruiser.cjs packages apps/desktop/electron apps/desktop/src apps/mobile-poc/src",
    "clean": "turbo run clean && rm -rf node_modules .turbo"
  },
  "devDependencies": {
    "@moxxy/config": "workspace:*",
    "@types/node": "catalog:",
    "dependency-cruiser": "^16.0.0",
    "eslint": "^9.18.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "tsx": "catalog:",
    "turbo": "^2.5.0",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "pnpm": {
    "packageExtensions": {
      "@clerk/clerk-react@*": {
        "dependencies": {
          "@types/react": "^18.3.0"
        }
      },
      "@clerk/shared@*": {
        "dependencies": {
          "@types/react": "^18.3.0"
        }
      },
      "react-native-worklets@0.8.3": {
        "dependencies": {
          "@babel/generator": "^7.29.7",
          "@babel/traverse": "^7.29.7",
          "@babel/types": "^7.29.7"
        }
      },
      "react-virtuoso@*": {
        "dependencies": {
          "@types/react": "^18.3.0"
        }
      }
    },
    "onlyBuiltDependencies": [
      "esbuild",
      "electron",
      "electron-winstaller",
      "node-pty"
    ],
    "supportedArchitectures": {
      "os": ["current"],
      "cpu": ["x64", "arm64"]
    }
  },
  "license": "MIT"
}

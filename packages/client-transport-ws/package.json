{
  "name": "@moxxy/client-transport-ws",
  "private": true,
  "version": "0.2.0",
  "description": "A MoxxyApi (invoke/subscribe) backed by a WebSocket + minimal JSON-RPC client, for remote clients (the Expo mobile app) talking to the desktop host's WebSocket bridge. Uses the global WebSocket (no Node 'ws', no @moxxy/runner) so it bundles cleanly under Metro/React Native.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@moxxy/desktop-ipc-contract": "workspace:*",
    "@moxxy/e2e": "workspace:*"
  },
  "devDependencies": {
    "@moxxy/tsconfig": "workspace:*",
    "@moxxy/vitest-preset": "workspace:*",
    "@types/node": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}

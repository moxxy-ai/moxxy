{
  "name": "@moxxy/plugin-channel-mobile",
  "private": true,
  "version": "0.1.25",
  "description": "Mobile channel: serves the moxxy IPC contract over an authenticated WebSocket (via @moxxy/ipc-server-ws), backed by the runner's single Session, so the Expo app reuses @moxxy/client-core. Runs standalone (`moxxy mobile`) or alongside other channels (`moxxy serve --all`).",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./pairing": {
      "types": "./dist/pairing.d.ts",
      "import": "./dist/pairing.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@moxxy/desktop-ipc-contract": "workspace:*",
    "@moxxy/ipc-server-ws": "workspace:*",
    "@moxxy/plugin-channel-web": "workspace:*",
    "@moxxy/sdk": "workspace:*",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@moxxy/tsconfig": "workspace:*",
    "@moxxy/vitest-preset": "workspace:*",
    "@types/node": "catalog:",
    "@types/qrcode": "^1.5.5",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}

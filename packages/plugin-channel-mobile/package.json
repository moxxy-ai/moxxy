{
  "name": "@moxxy/plugin-channel-mobile",
  "private": true,
  "version": "0.2.10",
  "description": "Mobile channel: serves the moxxy IPC contract over an authenticated WebSocket (via @moxxy/ipc-server-ws), backed by the runner's single Session, so the Expo app reuses @moxxy/client-core. Runs standalone (`moxxy mobile`) or alongside other channels (`moxxy serve --all`).",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./pairing": {
      "types": "./dist/pairing.d.ts",
      "import": "./dist/pairing.js"
    },
    "./e2e-proxy": {
      "types": "./dist/e2e-proxy.d.ts",
      "import": "./dist/e2e-proxy.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@moxxy/core": "workspace:*",
    "@moxxy/desktop-ipc-contract": "workspace:*",
    "@moxxy/e2e": "workspace:*",
    "@moxxy/ipc-server-ws": "workspace:*",
    "@moxxy/plugin-tunnel-proxy": "workspace:*",
    "@moxxy/sdk": "workspace:*",
    "@moxxy/workspace-registry": "workspace:*",
    "qrcode": "^1.5.4",
    "ws": "catalog:"
  },
  "devDependencies": {
    "@moxxy/tsconfig": "workspace:*",
    "@moxxy/vitest-preset": "workspace:*",
    "@types/node": "catalog:",
    "@types/qrcode": "^1.5.5",
    "@types/ws": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}

# Expo / EAS account identity for `eas build` (read by app.config.ts).
# Copy to `.env` (gitignored) and fill in YOUR values — these are never committed.
# In CI they come from the GitHub Actions secrets of the same name.

# Your Expo account/org username (the EAS project owner).
EXPO_OWNER=

# The EAS project UUID (`eas project:info`, or the dashboard URL
# https://expo.dev/accounts/<owner>/projects/<slug> → Project ID).
EAS_PROJECT_ID=

{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "jsx": "react-jsx",
    "moduleResolution": "Bundler",
    "skipLibCheck": true,
    "paths": {
      "@/*": [
        "./src/*"
      ]
    }
  },
  "include": [
    "index.js",
    "app/**/*",
    "src/**/*",
    "*.config.js",
    "tailwind.config.ts",
    "nativewind-env.d.ts",
    "nativewind-preset.d.ts",
    "./nativewind-env.d.ts"
  ]
}
{
  "$schema": "https://turbo.build/schema.json",
  "ui": "stream",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"],
      "inputs": ["src/**", "tsconfig*.json", "package.json"]
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "tsconfig*.json", "package.json"]
    },
    "lint": {
      "dependsOn": [],
      "inputs": ["src/**", "*.ts", "*.tsx", "*.js", "*.cjs", "*.mjs", "eslint.config.*"]
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"],
      "inputs": [
        "src/**",
        "test/**",
        "__fixtures__/**",
        "vitest.config.*",
        "tsconfig*.json",
        "package.json"
      ],
      "env": ["MOXXY_FIXTURES", "ANTHROPIC_API_KEY"]
    },
    "test:watch": {
      "cache": false,
      "persistent": true
    },
    "clean": {
      "cache": false
    }
  }
}

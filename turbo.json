{
  "$schema": "https://turbo.build/schema.json",
  "ui": "stream",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "*.tsbuildinfo"],
      "inputs": [
        "src/**",
        "skills/**",
        "scripts/**",
        "tsup.config.ts",
        "tsconfig*.json",
        "package.json"
      ]
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "tsconfig*.json", "package.json"]
    },
    "test": {
      "dependsOn": ["^build"],
      "inputs": [
        "src/**",
        "test/**",
        "__fixtures__/**",
        "vitest.config.*",
        "tsconfig*.json",
        "package.json"
      ],
      "env": ["MOXXY_FIXTURES", "ANTHROPIC_API_KEY"]
    },
    "test:watch": {
      "cache": false,
      "persistent": true
    },
    "clean": {
      "cache": false
    }
  }
}
